---
import { SignedIn, SignedOut, UserButton, SignInButton } from '@clerk/astro/components'
import { ModeToggle } from '../ModeToggle'
import { Search, LogIn } from 'lucide-react'

import MobileTabs from "@/components/nav/MobileTabs.astro"
import NavMenu from '@/components/nav/NavMenu.astro'
---

<div class="bg-[#F2613F] h-6"></div>

<div class="border-b">
    <div class="p-4 flex justify-between items-center">
        <div class="flex items-center gap-4 lg:gap-8">

            <div class="lg:hidden mt-0.5">
                <NavMenu />
            </div>
    
            <a href="/" class="text-4xl font-bold mb-[1px]">TEKER</a>
    
            <div class='hidden sm:block '>
                <div class='flex justify-between items-center rounded-[20px] 
                bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] 
                dark:border-[#404258]'>
                    <Search size={17} className='ml-4' />
                    <input 
                        type="text" 
                        placeholder='Search anything..'
                        class='px-4 py-1.5 rounded-[20px] w-full bg-[#F7F7F7] 
                        focus:outline-none dark:bg-[#1f1f23]' />
                </div>
            </div>
    
        </div>
        <div class="flex items-center gap-4 lg:gap-8">
            <ModeToggle client:load />
            <SignedOut>
                <SignInButton mode='modal'>
                    <div class='bg-[#1DCD9F] border border-[#169976] px-4 py-1.5 
                    rounded-[20px] cursor-pointer flex items-center gap-3'>
                        <span><LogIn size={16} className='my-1 md:my-0 text-[#030303]' />
                        </span>
                        <span class='hidden sm:block text-[#030303]'>Sign In</span>
                    </div>
                </SignInButton>
            </SignedOut>
            <SignedIn>
                <UserButton />
            </SignedIn>
        </div>
    </div>
    
    <div class='mx-4 mb-4 flex justify-between items-center rounded-[20px] sm:hidden
        bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258]'>
            <Search size={17} className='ml-4' />
            <input 
                type="text" 
                placeholder='Search anything..'
                class='px-4 py-2 rounded-[20px] w-full bg-[#F7F7F7] focus:outline-none 
                dark:bg-[#1f1f23]' />
    </div>
</div>

<MobileTabs />