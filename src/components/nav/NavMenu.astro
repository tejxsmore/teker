// Helper function
const toKebabCase = (str: string) => {
  return str.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]+/g, '');
};

// Get current path
const { pathname } = Astro.url;
---

<div class="flex items-center relative">
  <button 
    id="menu-toggle" 
    class="lg:hidden text-3xl cursor-pointer z-50 flex items-center justify-center 
    focus:outline-none"
    aria-label="Toggle menu"
  >
    <Menu id="menu-icon" />
    <X id="close-icon" className="hidden" />
  </button>

  <!-- Overlay -->
  <div id="menu-overlay" class="fixed inset-0 z-30 bg-black/30 hidden"></div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed left-0 top-[96px] w-full bg-[#F7F7F7] dark:bg-[#1f1f23] z-40 h-[calc(100vh-60px)] hidden">
    <div class="border-t border-[#D8D9CF] dark:border-[#404258] flex h-full">
      <!-- Categories sidebar -->
      <div class="w-32 mb-24 bg-[#F7F7F7] dark:bg-[#1f1f23] overflow-y-auto border-r border-[#D8D9CF] dark:border-[#404258] p-5 space-y-5">
        {categories.map((cat, index) => (
          <button
            class={`category-btn w-full rounded-[20px] p-3 flex items-center justify-center text-center flex-col space-y-3 cursor-pointer border ${
              index === 0
                ? "bg-[#F2613F] border-[#D84040] active-category"
                : "bg-[#FFFFFF] dark:bg-[#030303] hover:bg-[#FEF3E2] dark:hover:bg-[#1A1A1D] hover:border-[#F2613F] dark:hover:border-[#F2613F] border-[#D8D9CF] dark:border-[#404258]"
            }`}
            data-category={cat.name}
          >
            <span class="text-3xl">{cat.img}</span>
            <span class="text-sm break-words leading-tight">{cat.name}</span>
          </button>
        ))}
      </div>

      <!-- Category content -->
      <div class="flex-1 p-5 overflow-y-auto mb-24">
        {categories.map((category, index) => (
          <div 
            class={`category-content ${index === 0 ? "block" : "hidden"}`} 
            data-category={category.name}
          >
            <h2 class="text-xl font-semibold mb-5">{category.name}</h2>
            <div class="flex flex-wrap -m-2">
              {category.subItems.map((item) => (
                <div class="w-1/2 md:w-1/3 p-2.5">
                  <a href={`/category/${toKebabCase(item.name)}/`}>
                    <div class="h-28 rounded-[20px] p-3 flex flex-col items-center justify-center text-sm text-center leading-snug break-words overflow-hidden dark:hover:bg-[#1A1A1D] hover:border-[#F2613F] transition hover:scale-102 hover:delay-75 cursor-pointer bg-[#FFFFFF] dark:bg-[#030303]">
                      <div class="w-12 h-12 mb-3">
                        <img
                          src={item.img}
                          alt={item.name}
                          width={50}
                          height={50}
                        />
                      </div>
                      <span class="text-xs sm:text-sm font-medium">{item.name}</span>
                    </div>
                  </a>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  // This code runs on the client
  function setupMobileMenu() {
    // Get DOM elements
    const menuToggle = document.getElementById('menu-toggle');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const menuOverlay = document.getElementById('menu-overlay');
    const mobileMenu = document.getElementById('mobile-menu');
    const categoryButtons = document.querySelectorAll('.category-btn');
    const categoryContents = document.querySelectorAll('.category-content');
    
    // Check if elements exist
    if (!menuToggle || !menuIcon || !closeIcon || !menuOverlay || !mobileMenu) {
      console.error('Mobile menu elements not found');
      return;
    }
    
    // Menu state
    let isMenuOpen = false;
    
    // Toggle menu function
    function toggleMenu() {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        // Open menu
        menuIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        menuOverlay?.classList.remove('hidden');
        mobileMenu?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        // Close menu
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        menuOverlay?.classList.add('hidden');
        mobileMenu?.classList.add('hidden');
        document.body.style.overflow = '';
      }
    }
    
    // Add click event to menu toggle button
    menuToggle.addEventListener('click', toggleMenu);
    
    // Close menu when clicking overlay
    menuOverlay.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu();
    });
    
    // Close menu on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) toggleMenu();
    });
    
    // Handle category selection
    categoryButtons.forEach(button => {
      button.addEventListener('click', () => {
        const selectedCategory = button.getAttribute('data-category');
        
        // Update active button
        categoryButtons.forEach(btn => {
          if (btn.getAttribute('data-category') === selectedCategory) {
            btn.classList.add('bg-[#F2613F]', 'border-[#D84040]', 'active-category');
            btn.classList.remove('bg-[#FFFFFF]', 'dark:bg-[#030303]');
          } else {
            btn.classList.remove('bg-[#F2613F]', 'border-[#D84040]', 'active-category');
            btn.classList.add('bg-[#FFFFFF]', 'dark:bg-[#030303]');
          }
        });
        
        // Show selected content
        categoryContents.forEach(content => {
          if (content.getAttribute('data-category') === selectedCategory) {
            content.classList.remove('hidden');
            content.classList.add('block');
          } else {
            content.classList.add('hidden');
            content.classList.remove('block');
          }
        });
      });
    });
    
    // Close menu on navigation (for client-side routing)
    document.addEventListener('astro:after-navigation', () => {
      if (isMenuOpen) toggleMenu();
    });
  }

  // Run setup when DOM is ready
  document.addEventListener('DOMContentLoaded', setupMobileMenu);
  
  // For Astro's view transitions
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>