---
const slugify = (text: string) =>
  text.toLowerCase().replace(/ /g, "-").replace(/[^a-z0-9-]/g, "");

const categories = [
  { name: "Phone", image: "/assets/category/phone.png" },
  { name: "Tablet", image: "/assets/category/tablet.png" },
  { name: "Laptop", image: "/assets/category/laptop.png" },
  { name: "Earbuds", image: "/assets/category/earbuds.png" },
  { name: "Headphone", image: "/assets/category/headphone.png" },
  { name: "Speaker", image: "/assets/category/speaker.png" },
  { name: "Watch", image: "/assets/category/watch.png" },
  { name: "Microphone", image: "/assets/category/microphone.png" },
  { name: "Drone", image: "/assets/category/drone.png" },
  { name: "Mice", image: "/assets/category/mice.png" },
  { name: "Rings", image: "/assets/category/rings.png" },
  { name: "Remarkable", image: "/assets/category/remarkable.png" },
];
---

<div class="p-4 overflow-x-auto">
  <div class="flex gap-4 min-w-max">
    {categories.map((category) => (
      <a
        href={`/category/${slugify(category.name)}`}
        class="flex flex-col items-center flex-shrink-0 w-24 sm:w-28 
              p-3 bg-[#F7F7F7] dark:bg-[#030303] rounded-[20px] transition hover:scale-103"
      >
        <div class="w-20 h-20 sm:w-16 sm:h-16 relative mb-2">
          <img
            src={category.image}
            alt={category.name}
            loading="lazy"
            width={100}
            height={100}
          />
        </div>
        <span class="text-xs sm:text-sm text-center font-medium">
          {category.name}
        </span>
      </a>
    ))}
  </div>
</div>