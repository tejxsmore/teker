---
import MainLayout from "@/layouts/MainLayout.astro";

const brands = [
  { name: "Apple", href: "/brand/apple", img: "/assets/logos/apple.png" },
  { name: "Samsung", href: "/brand/samsung", img: "/assets/logos/samsung.png" },
  { name: "Google", href: "/brand/google", img: "/assets/logos/google.png" },
  { name: "Oneplus", href: "/brand/oneplus", img: "/assets/logos/oneplus.png" },
  { name: "Xiaomi", href: "/brand/xiaomi", img: "/assets/logos/xiaomi.png" },
  { name: "Sony", href: "/brand/sony", img: "/assets/logos/sony.png" },
  { name: "Dell", href: "/brand/dell", img: "/assets/logos/dell.png" },
  { name: "Asus", href: "/brand/asus", img: "/assets/logos/asus.png" },
  { name: "NVIDIA", href: "/brand/nvidia", img: "/assets/logos/nvidia.png" },
  { name: "AMD", href: "/brand/amd", img: "/assets/logos/amd.png" },
];
---

<MainLayout >
    <div class="p-2.5 min-h-screen">
        <h1 class="text-2xl font-bold p-2.5">Top Brands</h1>
  
        <div class="flex flex-wrap">
          {brands.map((brand) => (
            <div class="w-1/2 sm:w-1/3 md:w-1/4 lg:w-1/5 p-2.5">
              <a href={brand.href}>
                <div
                  class="h-full p-5 rounded-2xl text-center text-xl font-medium 
                    bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258] 
                    hover:scale-102 transition space-y-5 flex flex-col justify-center 
                    items-center cursor-pointer"
                >
                  <img
                    src={brand.img}
                    alt={`${brand.name} logo`}
                    width={60}
                    height={60}
                    class="object-contain"
                  />
                  <p class="text-lg font-normal">{brand.name}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
</MainLayout>