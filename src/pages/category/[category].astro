---
import MainLayout from "@/layouts/MainLayout.astro";
import ProductCard from "@/components/card/ProductCard";
import { X, MoveUp, MoveDown } from "lucide-react";

interface Brand {
  name: string;
  slug: string;
}

interface Product {
  id: string;
  name: string;
  slug: string;
  price: number;
  description: string;
  image: { url: string };
  rating: number;
  brand: {
    name: string;
    slug: string;
  };
}

interface Category {
  slug: string;
  name: string;
  product: Product[];
}

const { category } = Astro.params;

const query = {
  method: "POST",
  headers: { "Content-Type": "application/json" },
  body: JSON.stringify({
    query: `
      {
        categories {
          name
          slug
          product {
            id
            name
            slug
            price
            description
            image { url }
            rating
            brand {
              name
              slug
            }
          }
        }
      }
    `,
  }),
};

const response = await fetch(import.meta.env.HYGRAPH_API, query);
const json = await response.json();

const categories: Category[] = json?.data?.categories || [];
const categoryData: Category | undefined = categories.find(
  (item) => item.slug === category
);

const uniqueBrands: Brand[] = categoryData
  ? Array.from(new Map(categoryData.product.map(p => [p.brand.slug, p.brand])).values())
  : [];

const productData: Product[] = categoryData?.product || [];
---

<MainLayout>
  <div class="flex flex-wrap justify-between px-4 pt-4 gap-4">
    <div class="flex gap-4 overflow-x-auto">
      {uniqueBrands.map((brand) => (
        <button
          class="cursor-pointer px-4 py-1.5 rounded-full border flex items-center gap-2 transition-all"
          onclick={`toggleBrand('${brand.slug}')`}
          data-slug={brand.slug}
          id={`btn-${brand.slug}`}
        >
          <span>{brand.name}</span>
          <X className="hidden close-icon w-4 h-4 text-[#f2613f]" />
        </button>
      ))}
    </div>

    <div class="relative inline-block">
      <button 
        id="sort-button"
        class="cursor-pointer px-4 py-1.5 rounded-[20px] border flex items-center gap-2 transition-all duration-100 ease-in-out hover:opacity-90 min-w-[140px] justify-between"
        onclick="toggleSortDropdown()"
      >
        <span id="sort-selected">Sort by</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="sort-chevron">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </button>

      <div 
        id="sort-dropdown" 
        class="absolute z-10 mt-2 rounded-[20px] border border-gray-300 dark:border-gray-600 bg-white dark:bg-black shadow-lg hidden w-full overflow-hidden"
      >
        <div class="p-1">
          <button data-value="asc" class="flex gap-2 items-center sort-option w-full text-left px-4 py-1.5 text-sm rounded-[20px] hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
            <MoveUp size={16} />
            Price: Low to High
          </button>
          <button data-value="desc" class="flex gap-2 items-center sort-option w-full text-left px-4 py-1.5 text-sm rounded-[20px] hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
            <MoveDown size={16} />
            Price: High to Low
          </button>
        </div>
      </div>
    </div>
  </div>

  <div id="product-grid" class="p-4 grid gap-4 grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 min-h-screen transition-all">
    {productData.map((product) => (
      <div class="product-item transition-opacity" data-brand={product.brand.slug} data-price={product.price}>
        <ProductCard
          id={product.id}
          brand={product.brand.name}
          name={product.name}
          slug={product.slug}
          image={ product.image.url }
          price={product.price}
          client:load
        />
      </div>
    ))}
  </div>

  <script is:inline>
    const activeBrands = new Set();
    let currentSortValue = "";

    function toggleBrand(slug) {
      const btn = document.getElementById(`btn-${slug}`);
      const icon = btn.querySelector(".close-icon");
      const productItems = document.querySelectorAll(".product-item");

      if (activeBrands.has(slug)) {
        activeBrands.delete(slug);
        btn.classList.remove("!bg-[#f2613f]", "!text-white", "!border-[#E83F25]");
        icon?.classList.remove("text-white");
        icon?.classList.add("text-[#f2613f]", "hidden");
      } else {
        activeBrands.add(slug);
        btn.classList.add("!bg-[#f2613f]", "!text-white", "!border-[#E83F25]");
        icon?.classList.remove("hidden", "text-[#f2613f]");
        icon?.classList.add("text-white");
      }

      applyFilters();
      updateURLParams();
    }

    function toggleSortDropdown() {
      const dropdown = document.getElementById("sort-dropdown");
      const chevron = document.getElementById("sort-chevron");
      dropdown.classList.toggle("hidden");
      dropdown.classList.contains("hidden")
        ? chevron.classList.remove("rotate-180")
        : chevron.classList.add("rotate-180");
    }

    document.addEventListener("click", (event) => {
      const sortButton = document.getElementById("sort-button");
      const dropdown = document.getElementById("sort-dropdown");
      if (!sortButton.contains(event.target) && !dropdown.contains(event.target)) {
        dropdown.classList.add("hidden");
        document.getElementById("sort-chevron").classList.remove("rotate-180");
      }
    });

    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll(".sort-option").forEach(option => {
        option.addEventListener("click", () => {
          const value = option.dataset.value;
          const text = option.textContent.trim();
          document.getElementById("sort-selected").textContent = text;
          const sortButton = document.getElementById("sort-button");

          value
            ? sortButton.classList.add("!bg-[#f2613f]", "!text-white", "!border-[#E83F25]")
            : sortButton.classList.remove("!bg-[#f2613f]", "!text-white", "!border-[#E83F25]");

          document.getElementById("sort-dropdown").classList.add("hidden");
          document.getElementById("sort-chevron").classList.remove("rotate-180");

          currentSortValue = value;
          applyFilters();
          updateURLParams();
        });
      });
    });

    function applyFilters() {
      const productGrid = document.getElementById("product-grid");
      const selected = Array.from(activeBrands);
      let items = Array.from(productGrid.children);

      items.forEach(item => {
        item.style.display = selected.length === 0 || activeBrands.has(item.dataset.brand) ? "block" : "none";
      });

      if (currentSortValue) {
        items.sort((a, b) => {
          const priceA = parseFloat(a.dataset.price);
          const priceB = parseFloat(b.dataset.price);
          return currentSortValue === "asc" ? priceA - priceB : priceB - priceA;
        });
        items.forEach(item => productGrid.appendChild(item));
      }
    }

    function updateURLParams() {
      const url = new URL(window.location.href);
      const brands = Array.from(activeBrands);
      brands.length > 0 ? url.searchParams.set("brands", brands.join(",")) : url.searchParams.delete("brands");
      currentSortValue ? url.searchParams.set("sort", currentSortValue) : url.searchParams.delete("sort");
      window.history.replaceState({}, "", url);
    }

    window.addEventListener("DOMContentLoaded", () => {
      const params = new URLSearchParams(window.location.search);
      const brands = params.get("brands");
      const sort = params.get("sort");

      if (brands) brands.split(",").forEach(slug => document.getElementById(`btn-${slug}`)?.click());
      if (sort) {
        currentSortValue = sort;
        document.querySelectorAll(".sort-option").forEach(option => {
          if (option.dataset.value === sort) {
            document.getElementById("sort-selected").textContent = option.textContent.trim();
            document.getElementById("sort-button").classList.add("!bg-[#f2613f]", "!text-white", "!border-[#E83F25]");
            applyFilters();
          }
        });
      }
    });
  </script>
</MainLayout>