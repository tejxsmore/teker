---
import MainLayout from "@/layouts/MainLayout.astro";
import { ArrowRight, Box, CircleArrowRight, ListCheck, Settings } from "lucide-react";

const user = await Astro.locals.currentUser();
const userFullName = user?.fullName ?? "Guest";
const userEmail = user?.emailAddresses?.[0]?.emailAddress ?? "";
const balance = 2700;

const INRupee = new Intl.NumberFormat("en-IN", {
  style: "currency",
  currency: "INR",
});
---

<MainLayout>
    <div class="p-5 space-y-5 min-h-screen md:flex md:gap-5">
        <div class="space-y-5 md:w-1/2">
          <div class="rounded-[20px] bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258]">
            <div class="p-5 space-y-2.5">
              <h2 class="text-2xl font-semibold">{userFullName}</h2>
              <h2>{userEmail}</h2>
            </div>
            <a href="/profile/details" class="p-5 flex items-center gap-3 border-t border-[#D8D9CF] dark:border-[#404258] group">
              <p>Your details</p>
              <span class="transition-transform duration-200 ease-in-out group-hover:translate-x-1">
                <ArrowRight size={17} />
              </span>
            </a>
          </div>
      
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
            <a href="/profile/orders" class="flex items-center gap-3 p-5 rounded-[20px] bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258]">
              <Box size={17} />
              Orders
            </a>
            <a href="/profile/buy-again" class="flex items-center gap-3 p-5 rounded-[20px] bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258]">
              <CircleArrowRight size={17} />
              Buy Again
            </a>
            <a href="/profile/list" class="flex items-center gap-3 p-5 rounded-[20px] bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258]">
              <ListCheck size={17} />
              List
            </a>
            <a href="/profile/settings" class="flex items-center gap-3 p-5 rounded-[20px] bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258]">
              <Settings size={17} />
              Settings
            </a>
          </div>
        </div>
      
        <div class="p-5 md:w-1/2 md:h-full rounded-[20px] bg-[#F7F7F7] dark:bg-[#1f1f23] border border-[#D8D9CF] dark:border-[#404258] space-y-5">
          <h2 class="text-2xl font-semibold">Teker Money</h2>
          <div class="space-y-3">
            <p class="text-gray-500">Balance</p>
            <p class="text-4xl font-semibold">{INRupee.format(balance)}</p>
          </div>
      
          <button class="w-full bg-[#1DCD9F] border border-[#169976] px-4 py-1.5 rounded-[20px] cursor-pointer items-center gap-3 text-[#030303]">
            Withdraw
          </button>
      
          <div class="text-gray-500 pt-5 border-t-2 border-dashed border-[#D8D9CF] dark:border-[#404258]">
            <p>
              Teker money will be used for all your orders across categories and brands. You can withdraw it anytime into your bank account.
            </p>
          </div>
        </div>
      </div>
</MainLayout>