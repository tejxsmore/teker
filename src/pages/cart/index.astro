---
import MainLayout from '@/layouts/MainLayout.astro';
import redis from '@/lib/redis';
import CartCard from '@/components/card/CartCard'

// Initialize variables
let cartItems = [];
let isLoggedIn = false;
let userEmail = '';
let userId = '';

// Get user data
const user = await Astro.locals?.currentUser?.();

if (user) {
    isLoggedIn = true;
    userId = user.id;
    userEmail = user.emailAddresses?.[0]?.emailAddress;

    const key = `cart:${userId}:${userEmail}`;
    try {
        const redisCart = await redis.get(key);
        cartItems = redisCart ? JSON.parse(redisCart) : [];
    } catch (err) {
        console.error('Redis fetch failed:', err);
    }
}

// Helper functions for calculations
const calculateTotal = (items: any) => {
    return items.reduce((sum: any, item: any) => sum + item.price * item.quantity, 0);
};

const calculateItemCount = (items: any) => {
    return items.reduce((sum: any, item: any) => sum + item.quantity, 0);
};

// Format currency
const INRupee = new Intl.NumberFormat("en-IN", {
    style: "currency",
    currency: "INR",
});

// Calculate totals for server-side rendering
const cartTotal = calculateTotal(cartItems);
const itemCount = calculateItemCount(cartItems);
const itemLabel = itemCount > 1 ? 'items' : 'item';
---

<MainLayout title="Your Cart">
    <div class="p-4 lg:flex lg:flex-row-reverse md:gap-4 space-y-4 tracking-wide min-h-screen">
        {isLoggedIn ? (
            <>
                {cartItems.length === 0 ? (
                    <div class="p-4 space-y-4 text-lg font-medium min-h-screen">
                        Your cart is empty
                    </div>
                ) : (
                    <>
                        <!-- Summary Card -->
                        <div class="p-4 bg-[#F7F7F7] dark:bg-[#030303] border border-[#D8D9CF] dark:border-[#404258] md:h-full lg:w-1/3 rounded-[20px] space-y-4">
                            <h2 class="text-2xl font-semibold pb-4 border-b-2 border-dashed border-[#D8D9CF] dark:border-[#404258]">
                                Summary
                            </h2>

                            <div class="text-lg font-normal flex justify-between items-center">
                                <p>{`Price (${cartItems.length} ${cartItems.length > 1 ? 'items' : 'item'})`}</p>
                                <p>{INRupee.format(cartTotal)}</p>
                            </div>

                            <div class="text-lg font-normal flex justify-between items-center">
                                <p>Quantity</p>
                                <p>{itemCount}</p>
                            </div>

                            <div class="text-lg font-normal flex justify-between items-center">
                                <p>Shipping</p>
                                <p class="text-[#1DCD9F] font-semibold">Free</p>
                            </div>

                            <div class="text-lg font-normal pt-4 border-t-2 border-dashed border-[#D8D9CF] dark:border-[#404258] flex justify-between items-center">
                                <p>Total Amount</p>
                                <p>{INRupee.format(cartTotal)}</p>
                            </div>

                            <a href="/checkout" class="block w-full bg-[#1DCD9F] border border-[#169976] px-4 py-3 rounded-[20px] cursor-pointer text-center font-medium text-[#030303]">
                                Proceed to Checkout
                            </a>

                            <div class="text-sm text-gray-600 pt-5 md:text-justify border-t-2 border-dashed border-[#D8D9CF] dark:border-[#404258]">
                                <p>
                                    By placing an order, you agree to our payment and purchase terms.
                                    Prices include applicable taxes unless stated otherwise.
                                </p>
                            </div>
                        </div>

                        <!-- Cart Items List -->
                        <div class="lg:w-2/3 space-y-4">
                            {cartItems.map((item : any) => (
                                <CartCard
                                    id={item.id}
                                    brand={item.brand}
                                    name={item.name}
                                    price={item.price}
                                    image={item.imageUrl}
                                    quantity={item.quantity}
                                    userId={userId}
                                    userEmail={userEmail}
                                />
                            ))}
                        </div>
                    </>
                )}
            </>
        ) : null}
    </div>
</MainLayout>