---
import MainLayout from "@/layouts/MainLayout.astro";
import { marked } from "marked";

export function getStaticPaths() {
  return [
    { params: { product: "iphone-16" }},
    { params: { product: "iphone-16-plus" }},
    { params: { product: "iphone-16-pro" }},
    { params: { product: "iphone-16-pro-max" }},
    { params: { product: "s25" }},
    { params: { product: "s25-ultra" }},
  ];
}

interface Product {
  id: string;
  brand: { name: string };
  name: string;
  slug: string;
  price: number;
  description: string;
  images: { id: string; url: string }[];
  rating: number;
}

const { product } = Astro.params;

const query = {
  method: "POST",
  headers: { "Content-Type": "application/json" },
  body: JSON.stringify({
    query: `
      {
        products {
          id
          brand { name }
          name
          slug
          price
          description
          images { id url }
          rating
        }
      }
    `,
  }),
};

const response = await fetch(import.meta.env.HYGRAPH_API, query);
const json = await response.json();
const item: Product | undefined = json.data.products.find((p: Product) => p.slug === product);

if (!item) {
  throw new Error(`Product not found for slug: ${product}`);
}

const descriptionHtml = marked.parse(item.description);

const INRupee = new Intl.NumberFormat("en-IN", {
  style: "currency",
  currency: "INR",
});
---

<MainLayout title={`${item.brand.name} ${item.name} ✨`} description={descriptionHtml}>
  <div class="p-5 space-y-5">
    <div>
      <h2 class="text-xl font-semibold">{item.brand.name}</h2>
      <h1 class="text-2xl font-bold">{item.name}</h1>
    </div>
    <p class="text-2xl font-bold text-gray-400">{INRupee.format(item.price)}</p>
    <div class="prose prose-lg" set:html={descriptionHtml}></div> 
  </div>
</MainLayout>
